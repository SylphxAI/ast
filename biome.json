{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"extends": ["@sylphx/biome-config"],
	"files": {
		"includes": [
			"!**/dist",
			"!**/node_modules",
			"!**/.turbo",
			"!packages/javascript/src/generated",
			"!**/.groundatlas*",
			"!**/.vitepress/cache",
			"!**/.vitepress/dist"
		]
	},
	"overrides": [
		{
			"includes": ["docs/public/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noSvgWithoutTitle": "off"
					}
				}
			}
		}
	]
}
